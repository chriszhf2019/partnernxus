.lottery { padding: 24rpx; }
.name-scroll { height: 200rpx; overflow: hidden; position: relative; }
.roll-name { display: block; text-align: center; padding: 16rpx; font-size: 36rpx; color: var(--color-text-muted); transition: all 0.05s; }
.roll-name.active { color: var(--color-text); font-size: 48rpx; font-weight: 800; background: linear-gradient(135deg, #fef3c7, #fde68a); border-radius: var(--radius); }
