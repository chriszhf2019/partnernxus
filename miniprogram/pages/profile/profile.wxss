.page { min-height: 100vh; padding-bottom: 40rpx; }
.profile-hero { background: #fff; text-align: center; border-bottom: 1rpx solid var(--color-border); }
.avatar-lg { width: 120rpx; height: 120rpx; border-radius: 50%; background: #e2e8f0; margin: 0 auto; }
.company-input { width: 100%; height: 72rpx; padding: 0 16rpx; border: 1rpx solid var(--color-border); border-radius: var(--radius); font-size: 28rpx; }
.company-item { padding: 16rpx; border-radius: var(--radius); background: #f8fafc; margin-bottom: 8rpx; }
.company-item:active { background: #e2e8f0; }
