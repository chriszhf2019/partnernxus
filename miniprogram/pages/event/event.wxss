.page { min-height: 100vh; padding-bottom: 40rpx; }
.event-hero { background: #fff; border-bottom: 1rpx solid var(--color-border); }
.agenda-item { display: flex; padding: 16rpx 0; position: relative; }
.agenda-item:not(:last-child) { border-left: 2rpx solid var(--color-border); margin-left: 8rpx; padding-left: 24rpx; }
.time-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--color-border); position: absolute; left: -9rpx; top: 20rpx; }
.time-dot.active { background: var(--color-brand); box-shadow: 0 0 0 6rpx rgba(37,99,235,0.2); }
.question-input { flex: 1; height: 72rpx; padding: 0 16rpx; border: 1rpx solid var(--color-border); border-radius: var(--radius); font-size: 28rpx; }
.avatar-sm { width: 56rpx; height: 56rpx; border-radius: 50%; background: #e2e8f0; }
.question-item { padding: 16rpx 0; }
.question-item:not(:last-child) { border-bottom: 1rpx solid var(--color-border); }
.reply-box { background: #f0f9ff; padding: 12rpx 16rpx; border-radius: var(--radius); border-left: 4rpx solid var(--color-brand); }
.lottery-card { background: linear-gradient(135deg, #fef3c7, #fde68a); }
